# Google Sheets API (Signups Marketing)
# Spreadsheet ID from URL: https://docs.google.com/spreadsheets/d/<THIS_ID>/edit
# Expected sheets: Signups (with Person ID column), Expa Application (Unique Person ID), Members Info (name, department)
GOOGLE_SHEETS_SPREADSHEET_ID=1TLgtxeqNfbS8dwL4tzUdgQzDpd_DAx_KkDQhWO0SOWc

# Service account auth (use one of the two):
# Option A: JSON key as a single-line string (e.g. for Vercel/hosted env)
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Option B: Path to key file (e.g. for local development)
# GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account-key.json

# Create a service account in Google Cloud Console, enable Sheets API, then share the target
# Google Sheet with the service account email (Editor or Viewer).

# Use live data from the API (and Google Sheet). Omit or set to false to use mock data in the app.
# NEXT_PUBLIC_USE_LIVE_DATA=true
